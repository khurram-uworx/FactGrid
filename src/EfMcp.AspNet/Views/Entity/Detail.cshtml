@model long
@{
    var entity = ViewBag.Entity as EntityRegistration;
    ViewData["Title"] = entity?.DisplayName ?? "Entity";
}

<h1>@entity?.DisplayName</h1>
<p class="text-muted">@entity?.Description</p>

<div class="alert alert-info">
    <strong>@Model</strong> record(s) in <code>@entity?.TableName</code> table.
    <br/>
    <small>MCP endpoint: <code>/api/mcp/@entity?.EntityName</code></small>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Upload Excel File</div>
            <div class="card-body">
                <form method="post" asp-action="Upload" asp-route-entityName="@entity?.EntityName" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" name="file" class="form-control" accept=".xlsx" />
                    </div>
                    <button type="submit" class="btn btn-primary">Upload</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Manage Data</div>
            <div class="card-body">
                <form method="post" asp-action="DeleteAll" asp-route-entityName="@entity?.EntityName" onsubmit="return confirm('Delete all records? This cannot be undone.');">
                    <button type="submit" class="btn btn-danger">Delete All</button>
                </form>
            </div>
        </div>
    </div>
</div>
